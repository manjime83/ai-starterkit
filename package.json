{
  "name": "ai-starterkit",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently --names \"next,studio,stripe\" \"pnpm dev\" \"pnpm db:studio\" \"pnpm stripe:dev\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postlint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "email:dev": "email dev src/emails",
    "stripe:dev": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook",
    "auth:generate": "better-auth generate --output src/db/schema/auth.ts --yes",
    "test": "tsx --env-file=.env src/scripts/test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/client-sesv2": "^3.1081.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@base-ui/react": "^1.6.0",
    "@better-auth/stripe": "^1.6.20",
    "@hookform/resolvers": "^5.4.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "better-auth": "^1.6.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "next-safe-action": "^8.5.5",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-email": "^6.6.4",
    "react-hook-form": "^7.80.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "stripe": "^22.2.3",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@tsconfig/next": "^2.0.6",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "auth": "^1.6.20",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
