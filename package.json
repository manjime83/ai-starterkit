{
  "name": "ai-starterkit",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:all": "concurrently --names \"next,studio\" \"pnpm dev\" \"pnpm db:studio\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postlint": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "email:dev": "email dev src/emails",
    "polar:webhook": "ngrok http 3000",
    "auth:generate": "better-auth generate --output src/db/schema/auth.ts -y",
    "test": "tsx src/scripts/test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@base-ui/react": "^1.5.0",
    "@hookform/resolvers": "^5.4.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@polar-sh/better-auth": "^1.8.4",
    "@polar-sh/sdk": "^0.48.1",
    "@t3-oss/env-nextjs": "^0.13.11",
    "better-auth": "^1.6.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-safe-action": "^8.5.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.11",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^6.6.0",
    "react-hook-form": "^7.79.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tsconfig/next": "^2.0.6",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-drizzle": "^0.2.3",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
